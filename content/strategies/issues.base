filters:
  and:
    - file.tags.contains("newsletter")
    - '!file.name.contains("index")'
properties:
  file.name:
    displayName: Issue
  note.description:
    displayName: What it's about
  note.date:
    displayName: Date
views:
  - type: table
    name: All Issues
    order:
      - file.name
      - description
      - date
    sort:
      - property: date
        direction: DESC
